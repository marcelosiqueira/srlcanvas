# Connection string do MySQL (Prisma)
# Dev local (Docker): mysql://root:root@127.0.0.1:3307/srlcanvas
# Testes usam o database srlcanvas_test na mesma instancia — crie com:
#   docker exec srl-mysql mysql -uroot -proot -e "CREATE DATABASE IF NOT EXISTS srlcanvas_test"
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Segredo usado para assinar os JWTs (minimo 32 caracteres)
JWT_SECRET="troque-por-um-segredo-com-no-minimo-32-chars"

# Porta e host do servidor HTTP (opcionais)
PORT=3333
HOST=0.0.0.0

# development | test | production (opcional, default: development)
NODE_ENV=development
