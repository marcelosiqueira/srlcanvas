# URL base da API (vazio = modo local sem conta)
VITE_API_URL=/api

# Pesquisa academica (governanca do instrumento aprovado no comite de etica)
VITE_RESEARCH_SURVEY_ENABLED=true
VITE_RESEARCH_SURVEY_ACTIVE_VERSION=questionario_quantitativo_srl_canvas_revisado_2025-11-28

# Instrumentacao de metricas de produto (sem dados sensiveis)
VITE_PRODUCT_METRICS_ENABLED=true
